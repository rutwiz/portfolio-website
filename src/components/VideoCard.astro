---
interface Props {
  youtubeId: string;
  title: string;
  description?: string;
  date?: string;
}

const { youtubeId, title, description, date } = Astro.props;
const href = `https://www.youtube.com/watch?v=${youtubeId}`;
const thumb = `https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group block"
>
  <div
    class="relative aspect-video overflow-hidden rounded-lg border border-border transition-colors group-hover:border-accent"
  >
    <img
      src={thumb}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
    <div
      class="absolute inset-0 flex items-center justify-center bg-bg/20 transition-colors group-hover:bg-bg/10"
    >
      <span
        class="flex h-12 w-12 items-center justify-center rounded-full border border-border bg-bg/80 text-fg opacity-80 transition-all duration-300 group-hover:scale-110 group-hover:border-accent group-hover:text-accent group-hover:opacity-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="ml-0.5 h-5 w-5"
          aria-hidden="true"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </span>
    </div>
  </div>

  <h3 class="mt-3 font-mono text-fg transition-colors group-hover:text-accent">
    {title}
  </h3>
  {date && <p class="mt-1 font-mono text-xs text-faint">{date}</p>}
  {description && <p class="mt-1 text-sm text-muted">{description}</p>}
</a>
