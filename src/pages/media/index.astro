---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import VideoCard from "@/components/VideoCard.astro";

const importer = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/photos/*.{jpg,jpeg,png,webp,avif}"
);

const photos = await getCollection("photos");
const items = await Promise.all(
  photos.map(async (p) => {
    const loader = importer[`/src/assets/photos/${p.data.src}`];
    const image = loader ? (await loader()).default : null;
    return { ...p.data, image };
  })
);

const videos = await getCollection("videos");
---

<BaseLayout
  title="Media"
  description="Photography and video — a few frames and clips worth keeping."
>
  <section class="container-page py-16 sm:py-20">
    <p class="eyebrow">// media</p>
    <h1 class="mt-3 font-mono text-3xl tracking-tight sm:text-4xl">Media</h1>
    <p class="mt-4 max-w-prose text-muted">
      A small gallery of photography and video — frames I liked enough to keep,
      and clips from the channel.
    </p>

    <!-- Photography -->
    <div class="mt-14">
      <h2 class="font-mono text-xl tracking-tight">Photography</h2>
      {
        items.length > 0 ? (
          <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-2 md:grid-cols-3 sm:gap-4">
            {items.map((item) => (
              <figure class="group relative overflow-hidden rounded-lg border border-border transition-colors hover:border-accent">
                {item.image ? (
                  <Image
                    src={item.image}
                    alt={item.alt}
                    widths={[400, 800]}
                    sizes="(max-width:640px) 100vw, 400px"
                    class="aspect-square h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div class="flex aspect-square items-center justify-center bg-elevated">
                    <span class="font-mono text-xs text-faint">missing image</span>
                  </div>
                )}
                {(item.caption || item.location) && (
                  <figcaption class="absolute inset-x-0 bottom-0 translate-y-full bg-bg/85 px-3 py-2 backdrop-blur transition-transform duration-300 group-hover:translate-y-0">
                    {item.caption && (
                      <p class="text-xs text-fg">{item.caption}</p>
                    )}
                    {(item.location || item.date) && (
                      <p class="mt-0.5 font-mono text-xs text-faint">
                        {[item.location, item.date].filter(Boolean).join(" · ")}
                      </p>
                    )}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        ) : (
          <p class="mt-6 font-mono text-muted">No photos yet.</p>
        )
      }
    </div>

    <!-- Video -->
    <div class="mt-16">
      <h2 class="font-mono text-xl tracking-tight">Video</h2>
      {
        videos.length > 0 ? (
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {videos.map((v) => (
              <VideoCard
                youtubeId={v.data.youtubeId}
                title={v.data.title}
                description={v.data.description}
                date={v.data.date}
              />
            ))}
          </div>
        ) : (
          <p class="mt-6 font-mono text-muted">No videos yet.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
