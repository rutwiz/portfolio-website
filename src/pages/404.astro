---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="Page not found.">
  <section
    class="container-page flex min-h-[60vh] flex-col items-center justify-center py-20 text-center"
  >
    <p class="font-mono text-7xl font-semibold tracking-tight sm:text-8xl">
      404
    </p>
    <p class="mt-6 text-lg text-muted">
      This page wandered off. The link may be broken or the page moved.
    </p>
    <a
      href="/"
      class="mt-8 font-mono text-sm text-accent transition-colors hover:underline"
    >
      <span class="text-muted">$</span> cd ~ &mdash; back home -&gt;
    </a>
  </section>
</BaseLayout>
